# Copy to `public/.env`. Do not commit real values if the repo is shared.
# Use a host your browser can reach for Nakama (e.g. 127.0.0.1 when Nakama is on localhost).

VITE_NAKAMA_HOST=127.0.0.1
VITE_NAKAMA_PORT=7350
# Must match Nakama server key (default for local Docker image: defaultkey).
VITE_NAKAMA_SERVER_KEY=defaultkey
# Must match Nakama runtime.http_key (default for local image: defaulthttpkey).
VITE_NAKAMA_HTTP_KEY=defaulthttpkey
VITE_NAKAMA_USE_SSL=false
# Optional: ping Nakama every 5 min from the browser while the app is open (Render / idle hosts).
# VITE_HOSTING_KEEPALIVE=true