# Used by `vite build` / root `npm run build`. Public Render Nakama (Docker image defaults for keys).
VITE_NAKAMA_HOST=tic-tac-toe-multiplayer-m8l6.onrender.com
VITE_NAKAMA_PORT=443
VITE_NAKAMA_SERVER_KEY=defaultkey
VITE_NAKAMA_HTTP_KEY=defaulthttpkey
VITE_NAKAMA_USE_SSL=true
VITE_HOSTING_KEEPALIVE=true
