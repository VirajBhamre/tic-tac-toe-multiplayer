# Copy to `.env` in this directory. Docker Compose reads it automatically for variable substitution.
# Do not commit `.env`.

POSTGRES_USER=nakama
POSTGRES_PASSWORD=localdev
POSTGRES_DB=nakama
NAKAMA_DATABASE_ADDRESS=nakama:localdev@postgres:5432/nakama

# Frontend: run `cd public && npm run dev` and set `public/.env` (see `public/.env.example`).

# Optional: Nakama self-ping for hosts that sleep on idle (e.g. Render). Public origin where Nakama API is reachable (no path). Same http_key as Nakama runtime.
# KEEPALIVE_ORIGIN=https://your-nakama.onrender.com
# KEEPALIVE_HTTP_KEY=defaulthttpkey
# KEEPALIVE_INTERVAL_SEC=300
